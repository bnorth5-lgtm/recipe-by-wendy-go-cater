# Supabase Configuration
# Replace these with your actual Supabase project credentials.
# DO NOT commit the actual .env file to version control.
#
# Vercel / production: Project → Settings → Environment Variables → Production + Preview.
# Use these exact names. This Vite app only reads **`VITE_`-prefixed** variables in the browser.
# `SUPABASE_URL` alone (without VITE_) is NOT wired — Coordinate Lock inserts need the pair below.

VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Brave / Scout lane (production: set in Vercel Project → Settings → Environment Variables)
# VITE_BRAVE_SEARCH_MONTHLY_CALL_CAP defaults to 1000 (align with Masterpiece OPS ~$5 / 1000-unit Brave Shield metering).
VITE_BRAVE_SEARCH_API_KEY=
VITE_BRAVE_SEARCH_MONTHLY_CALL_CAP=1000
# Documentation / provisioning cue only — enforced in OPS UI; reminds operators of Scout charter.
VITE_SCOUT_WEB_BUDGET_USD=5
